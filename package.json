{
  "name": "pedigree-fhir",
  "version": "0.0.0",
  "private": true,
  "description": "Headless TypeScript library for displaying, generating, and managing 3-generation pedigree charts from FHIR resources.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" run build",
    "test": "pnpm -r --filter \"./packages/*\" run test",
    "test:coverage": "pnpm -r --filter \"./packages/*\" run test:coverage",
    "typecheck": "pnpm -r run typecheck",
    "lint": "biome check .",
    "format": "biome format --write .",
    "e2e": "playwright test",
    "e2e:update": "playwright test --update-snapshots"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^2.1.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
