{
  "name": "@pedigree-fhir/react",
  "version": "0.1.0",
  "description": "Headless React adapter for @pedigree-fhir/core: hooks and render-prop primitives, no styling.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/matheus-of-freitas/pedigree.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/matheus-of-freitas/pedigree/tree/main/packages/react#readme",
  "bugs": {
    "url": "https://github.com/matheus-of-freitas/pedigree/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "mutation": "stryker run stryker.config.json",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "dependencies": {
    "@pedigree-fhir/core": "workspace:^"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.1",
    "@types/react": "^18.3.12",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "tsup": "8.3.5",
    "typescript": "5.6.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
